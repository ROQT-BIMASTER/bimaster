# Lovable Cloud - Supabase Configuration
# Inside the Lovable sandbox, `.env` is auto-provisioned and regenerated on
# each session — DO NOT edit it manually. This `.env.example` exists for
# external clones (Cursor, local IDE, CI). Copy to `.env` and fill with the
# values shown in Lovable: Connectors → Lovable Cloud (URL + publishable key).
# `.env` is gitignored; never commit real values, even publishable ones.

VITE_SUPABASE_PROJECT_ID=your_project_id_here
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# Optional: Third-party API Keys (configure via Lovable Cloud Secrets)
# LOVABLE_API_KEY=configured_in_cloud_secrets
# OPENAI_API_KEY=configured_in_cloud_secrets
# MAPBOX_ACCESS_TOKEN=configured_in_cloud_secrets
# STRIPE_SECRET_KEY=configured_in_cloud_secrets

# Application Settings
NODE_ENV=production
