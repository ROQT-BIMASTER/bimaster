# Lovable Cloud — placeholder env for production build
# ============================================================================
# Copie para .env.production e preencha com os valores reais do seu projeto
# (Connectors → Lovable Cloud no editor Lovable).
#
# Os valores são PUBLISHABLE (anon-pública) — vão no bundle do browser.
# Mesmo assim, NÃO comite .env.production: a proteção real é RLS.
# ============================================================================

VITE_SUPABASE_PROJECT_ID=example-project-id
VITE_SUPABASE_URL=https://example.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=example-publishable-key
