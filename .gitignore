# Environment
# Segredos reais ficam fora do repo (.env, .env.local, .env.*.local).
# .env.production é versionado de propósito: contém só config PÚBLICA do
# cliente (VITE_SUPABASE_*), necessária no build pra evitar tela branca.
.env
.env.*
!.env.example
!.env.production.example
!.env.production
.env.local
.env.*.local

# Dependencies
node_modules/

# Build
dist/
dist-ssr/
build/
.next/
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Bun project — npm/yarn lockfiles must not be committed
package-lock.json
yarn.lock
pnpm-lock.yaml

# Supabase
.supabase/

# IDE / Editor
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db

# AI tooling drafts
.lovable/
.claude/
.cursor/
.aider*
*.aider.tmp

# Playwright (e2e)
playwright-report/
test-results/
playwright/.cache/

# Temporary
tmp/
temp/
