# Lovable Cloud auto-generated env (recreated per sandbox/clone)
# Contains only publishable VITE_SUPABASE_* values, but keep out of VCS for hygiene.
# Run `git rm --cached .env` once outside the Lovable agent to untrack the existing copy.
.env
.env.*.local
!.env.example

# Bun project — npm/yarn lockfiles must not be committed
package-lock.json
yarn.lock
pnpm-lock.yaml
