  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 vite build",
    "build:dev": "NODE_OPTIONS=--max-old-space-size=8192 vite build --mode development",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:strict": "node scripts/typecheck-strict.mjs",
    "lint": "NODE_OPTIONS=--max-old-space-size=8192 eslint .",
    "preview": "vite preview",
    "e2e:reset": "bun run scripts/seed/e2e-aprovacoes-reset.ts",
    "e2e:seed": "bun run scripts/seed/e2e-aprovacoes.ts",
    "e2e:matrix": "bash scripts/ci/run-e2e-matrix-local.sh",
    "e2e:smoke": "bunx playwright test --config=playwright.config.ts --grep @smoke",
    "e2e:tz:sp": "bunx playwright test --config=playwright.config.ts --project=tz-sao-paulo e2e/datepicker-tz",
    "e2e:tz:utc": "bunx playwright test --config=playwright.config.ts --project=tz-utc e2e/datepicker-tz",
    "e2e:tz:tokyo": "bunx playwright test --config=playwright.config.ts --project=tz-tokyo e2e/datepicker-tz",
    "e2e:tz": "bunx playwright test --config=playwright.config.ts --project=tz-sao-paulo --project=tz-utc --project=tz-tokyo e2e/datepicker-tz",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:tz:sp": "TZ=America/Sao_Paulo vitest run src/lib/utils/__tests__/parseLocalDate.test.ts",
    "test:tz:utc": "TZ=UTC vitest run src/lib/utils/__tests__/parseLocalDate.test.ts",
    "test:tz:tokyo": "TZ=Asia/Tokyo vitest run src/lib/utils/__tests__/parseLocalDate.test.ts",
    "test:tz": "npm run test:tz:sp && npm run test:tz:utc && npm run test:tz:tokyo",
    "lint:edge": "NODE_OPTIONS=--max-old-space-size=8192 eslint --config eslint.config.edge.js 'supabase/functions/**/*.ts' --max-warnings=999999"
  },
